{
  "instance_id": "promo-readiness",
  "agent_type": "inventory_diagnostic_agent",
  "display_name": "Promo Readiness",
  "description": "Ensures inventory is in place for upcoming promotional uplifts — detects promo supply gaps, explains promo-driven RC, recommends pre-build / transfer / phase-promo.",
  "icon": "LocalOfferOutlined",
  "button_text": "Promo Readiness",
  "button_style": "icon_and_text",
  "tooltip_text": "Focus: get ready for upcoming promotional windows",
  "module_slug": "meio-replenishment",
  "is_active": true,
  "type_specific_config": {
    "planning_horizon_weeks": 12,
    "enabled_intents": ["show", "diagnose", "solve", "simulate"],
    "enabled_library": {
      "problem_templates": ["promotion_supply_gap", "projected_stockout"],
      "root_cause_templates": ["promo_uplift", "late_supply", "network_imbalance"],
      "resolution_families": ["pre_build_inventory", "transfer_excess", "phase_promotion", "expedite_inbound"],
      "action_templates": ["create_task", "create_recommendation_record", "export_action_csv"]
    },
    "decision_graph_overrides": {"disabled_edges": []},
    "per_template_overrides": {
      "promotion_supply_gap": {
        "severity": {"default": "critical"}
      },
      "promo_uplift": {"weight": 0.45}
    },
    "prioritization_weights": {
      "revenue_at_risk": 0.35,
      "stockout_severity": 0.20,
      "customer_facing_flag": 0.25,
      "abc_class": 0.15,
      "lead_time_weeks": 0.05
    },
    "execute_mode": {"dispatch": false, "delivery_mode": "recommendation_record", "webhook_url": null, "csv_path": "/tmp/promo_readiness"},
    "action_permissions_per_intent": {
      "show": [],
      "diagnose": [],
      "solve": ["create_task", "create_recommendation_record", "export_action_csv"],
      "simulate": [],
      "execute": ["create_task", "create_recommendation_record"]
    }
  }
}
