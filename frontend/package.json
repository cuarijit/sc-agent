{
  "name": "supply-chain-planning",
  "version": "1.0.0",
  "description": "Supply Chain Planning and Execution - Intelligent Planning & Smart Execution",
  "author": "Puls8",
  "repository": {
    "type": "git",
    "url": "https://github.com/cuarijit/sc-agent.git"
  },
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "node scripts/dev-electron.cjs",
    "build:backend": "node scripts/build-backend.cjs",
    "electron:dist:win": "node scripts/guard-platform.cjs win32 && npm run build && npm run build:backend && electron-builder --win nsis --x64",
    "electron:dist:mac": "node scripts/guard-platform.cjs darwin && npm run build && npm run build:backend && electron-builder --mac dmg"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.2",
    "@mui/material": "^7.3.2",
    "@mui/x-data-grid": "^8.14.1",
    "@tanstack/react-query": "^5.66.8",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.3.0",
    "recharts": "^2.15.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^36.2.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.puls8.supplychainplanning",
    "productName": "Supply Chain Planning",
    "directories": {
      "output": "../release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/dist-electron/backend-api",
        "to": "backend/backend-api"
      },
      {
        "from": "../backend/data/seed",
        "to": "backend/data/seed"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.business",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "darkModeSupport": true
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
